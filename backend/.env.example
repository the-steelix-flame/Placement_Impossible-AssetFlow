# ── Django ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (local PostgreSQL via pgAdmin in dev; Supabase pooler in prod) ──
# In production point these at the Supabase pooler (host …pooler.supabase.com, port 6543).
POSTGRES_DB=assetflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-local-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Auth ───────────────────────────────────────────────────────────────
# The HS256 secret used to sign & verify JWTs. In production this is the
# Supabase project's JWT secret (Project Settings → API → JWT Secret).
# In local dev, any long random string works — `manage.py mint_token` signs
# test tokens with THIS value so the whole auth flow runs without Supabase.
SUPABASE_JWT_SECRET=local-dev-super-secret-jwt-signing-key-change-me
# Expected audience claim on Supabase tokens (leave as 'authenticated').
SUPABASE_JWT_AUD=authenticated

# ── CORS (frontend origins allowed to call the API) ────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Storage (Supabase Storage buckets — used later for photo uploads) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
