# ── Django ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (local PostgreSQL via pgAdmin in dev; Supabase pooler in prod) ──
# In production point these at the Supabase pooler (host …pooler.supabase.com, port 6543).
POSTGRES_DB=assetflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-local-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Auth ───────────────────────────────────────────────────────────────
# HS256 secret for LOCAL dev tokens only (`manage.py mint_token`). Any long
# random string. Independent of Supabase — real user tokens use ES256/JWKS below.
SUPABASE_JWT_SECRET=local-dev-super-secret-jwt-signing-key-change-me
# Expected audience claim on Supabase tokens (leave as 'authenticated').
SUPABASE_JWT_AUD=authenticated

# Real Supabase project. User access tokens are signed with the project's
# asymmetric key (ES256/RS256) and verified against the public JWKS, which is
# derived from SUPABASE_URL as {SUPABASE_URL}/auth/v1/.well-known/jwks.json.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=            # frontend-safe publishable key
SUPABASE_SERVICE_ROLE_KEY=    # backend-only admin key — NEVER expose to the client
# SUPABASE_JWKS_URL=          # optional override; auto-derived from SUPABASE_URL

# ── CORS (frontend origins allowed to call the API) ────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
